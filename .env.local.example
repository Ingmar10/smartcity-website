# Copy to .env.local for local development. NEVER commit real values.
# In production these are set as Vercel Environment Variables.

# Anthropic API key — powers the Bolt chat widget (/api/bolt).
# Get one at https://console.anthropic.com. Injected in Vercel, not committed.
ANTHROPIC_API_KEY=

# Vercel Postgres connection string — stores DialBolt TCPA consent records.
# Auto-populated when you provision Vercel Postgres and link it to the project.
# Leave blank locally to use the .data/consent.jsonl file fallback instead.
POSTGRES_URL=

# Public site URL (used for canonical/OG metadata). Defaults to the live domain.
NEXT_PUBLIC_SITE_URL=https://smartctycontractors.com
